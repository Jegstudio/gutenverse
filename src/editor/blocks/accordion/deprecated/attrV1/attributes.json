    },
    "contentBackgroundColorClosed": {
        "type": "object",
        "copyStyle": true
    },
    "contentBackgroundColorHover": {
        "type": "object",
        "copyStyle": true
    },
    "contentTextColor": {
        "type": "object",
        "copyStyle": true
    },
    "contentTextColorClosed": {
        "type": "object",
        "copyStyle": true
    },
    "contentTextColorHover": {
        "type": "object",
        "copyStyle": true
    },
    "contentBackgroundGradient": {
        "type": "object",
        "copyStyle": true
    },
    "contentBackgroundGradientClosed": {
        "type": "object",
        "copyStyle": true
    },
    "contentBackgroundGradientHover": {
        "type": "object",
        "copyStyle": true
    }
